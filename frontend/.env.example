# ─────────────────────────────────────────────
#  WMT Cinema Platform — Frontend Environment
#  Copy this file to .env and fill in the values
#  DO NOT commit the actual .env file to git
# ─────────────────────────────────────────────

# ── API Base URL ──────────────────────────────
# The EXPO_PUBLIC_ prefix is REQUIRED for Expo to expose this variable to the client bundle.
# All values here are public and will be embedded in the built app — never put secrets here.

# Local development (Android emulator):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5000/api

# Local development (Expo Go on a real device — replace with your machine's LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:5000/api

# Production (Railway deployment):
EXPO_PUBLIC_API_BASE_URL=https://your-railway-app.up.railway.app/api
